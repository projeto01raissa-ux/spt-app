# Pegue esses valores em Supabase > Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Usada SOMENTE em API routes server-side (nunca exposta ao navegador)
# Settings > API Keys > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
